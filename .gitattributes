###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Standard C# source files
*.cs text diff=csharp linguist-detectable -linguist-vendored -linguist-generated
*.cshtml text diff=html linguist-detectable -linguist-vendored -linguist-generated linguist-language=HTML
*.sln text eol=crlf
*.csproj text eol=crlf
*.config text eol=crlf
*.resx text eol=crlf

# Web files
*.html text
*.css text
*.js text
*.json text
*.md text

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Font files
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Documents
*.pdf binary
*.docx binary
*.xlsx binary

# Linguist Overrides (GitHub Language Statistics)
# 1. Mark folders as third-party (vendored)
APPClinet/wwwroot/lib/** linguist-vendored

# 2. Force show your personal JavaScript and CSS (even if minified)
APPClinet/wwwroot/lib/js/dist/app/** -linguist-vendored -linguist-generated linguist-detectable linguist-language=JavaScript
APPClinet/wwwroot/lib/js/dist/*.init.js -linguist-vendored -linguist-generated linguist-detectable linguist-language=JavaScript
APPClinet/wwwroot/lib/css/dist/en/** -linguist-vendored -linguist-generated linguist-detectable linguist-language=CSS
APPClinet/wwwroot/lib/css/dist/fa/** -linguist-vendored -linguist-generated linguist-detectable linguist-language=CSS

# 3. Force show all C# and CSHTML files
APPClinet/**/*.cs -linguist-vendored -linguist-generated linguist-detectable linguist-language=C#
APPClinet/**/*.cshtml -linguist-vendored -linguist-generated linguist-detectable linguist-language=HTML
